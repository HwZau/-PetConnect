# Environment Variables for Railway Deployment

# Database
MONGODB_URI=mongodb://mongo:your-mongodb-url-here

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend URL (Railway sẽ provide)
FRONTEND_URL=https://your-frontend-app-name.railway.app

# Node Environment
NODE_ENV=production

# Port (Railway tự động set)
PORT=8080