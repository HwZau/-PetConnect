# ========================
# BASIC CONFIGURATION
# ========================
VITE_APP_NAME=PawNest
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="Pet Care Community Platform"

# ========================
# API CONFIGURATION
# ========================
# Base URL for API calls
VITE_API_BASE_URL=http://localhost:7020/api
# API timeout in milliseconds (10 seconds)
VITE_API_TIMEOUT=10000
# Enable mock API for development
VITE_ENABLE_MOCK_API=false

# ========================
# AUTH CONFIGURATION
# ========================
# JWT token storage key
VITE_AUTH_TOKEN_KEY=pawnet_token
# Token expiration time in minutes
VITE_TOKEN_EXPIRE_MINUTES=60
# Enable/disable auth persistence
VITE_PERSIST_AUTH=true

# ========================
# UPLOAD CONFIGURATION
# ========================
# Maximum file size in bytes (5MB)
VITE_MAX_FILE_SIZE=5242880
# Allowed file types for uploads
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
# Maximum number of files per upload
VITE_MAX_FILES_PER_UPLOAD=5
# Image compression quality (1-100)
VITE_IMAGE_COMPRESSION_QUALITY=80

# ========================
# FEATURE FLAGS
# ========================
# Enable/disable analytics
VITE_ENABLE_ANALYTICS=false
# Enable/disable PWA features
VITE_ENABLE_PWA=false
# Enable/disable chat features
VITE_ENABLE_CHAT=true
# Enable/disable notifications
VITE_ENABLE_NOTIFICATIONS=true

# ========================
# APPEARANCE
# ========================
# Default theme (light/dark)
VITE_DEFAULT_THEME=light
# Enable/disable theme switcher
VITE_ENABLE_THEME_SWITCHER=true

# ========================
# PERFORMANCE
# ========================
# Enable/disable code splitting
VITE_ENABLE_CODE_SPLITTING=true
# Enable/disable image lazy loading
VITE_ENABLE_LAZY_LOADING=true
# Cache duration in minutes
VITE_CACHE_DURATION=60

# ========================
# DEVELOPMENT
# ========================
# Enable/disable debug mode
VITE_DEBUG_MODE=false
# Enable/disable API logging
VITE_API_LOGGING=true
# Development server port
VITE_DEV_SERVER_PORT=3000
