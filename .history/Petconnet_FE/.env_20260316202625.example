# Frontend Environment Variables

# API Base URL (Railway backend URL)
VITE_API_BASE_URL=https://your-backend-app-name.railway.app/api/v1

# WebSocket URL
VITE_WS_URL=wss://your-backend-app-name.railway.app

# Payment URLs
VITE_PAYMENT_SUCCESS_URL=https://your-frontend-app-name.railway.app/payment-success
VITE_PAYMENT_FAILURE_URL=https://your-frontend-app-name.railway.app/payment-failure